# ==============================
# 赛博僚机 环境变量配置
# ==============================

# ── 多模型配置 ───────────────────────────────────────────────
# 每个模型槽位通过 {NAME}_API_KEY / {NAME}_BASE_URL / {NAME}_MODEL 三个变量配置
# LLM_MODEL_PRIORITY 指定使用顺序（第一个为主模型，后续为降级备用）

LLM_MODEL_PRIORITY=kimi,gemini

# --- Kimi (主模型) ---
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5

# --- Gemini (备用模型) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://oricreate.org/v1/
GEMINI_MODEL=gemini-3-flash-preview-thinking-*

# --- 其他模型示例 (按需添加) ---
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
#
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# ── Agent 配置 ────────────────────────────────────────────────
# MAX_ITERATIONS=40
# MEMORY_WINDOW=100
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096

# ── 服务配置 ──────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
# WORKSPACE_DIR=./workspace

# ── 搜索工具 ──────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key

# ── Supabase 配置 ─────────────────────────────────────────────
# 从 https://supabase.com/dashboard/project/<id>/settings/api 获取
#
# 【Railway 后端填写这两个】
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # ⚠️ 绝对不能给前端！

# 【Vercel 前端填写这三个】
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co   # 与上面相同
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key          # Supabase 里 "anon/public" 那个
NEXT_PUBLIC_SITE_URL=https://your-vercel-app.vercel.app     # 你的 Vercel URL

# 【Vercel 前端】后端地址（Railway 生成的域名）
NEXT_PUBLIC_API_BASE_URL=https://your-railway-domain.up.railway.app

